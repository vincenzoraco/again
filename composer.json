{
    "name": "vincenzoraco/again",
    "description": "A PHP package to follow best practices when using loops",
    "license": "MIT",
    "authors": [
        {
            "name": "Vincenzo Raco",
            "email": "vincenzo@vincenzoraco.dev"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "jetbrains/phpstorm-attributes": "^1.0",
        "laravel/pint": "^1.0",
        "pestphp/pest": "^v3.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "VincenzoRaco\\Again\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VincenzoRaco\\Again\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-install-cmd": "cp hooks/* .git/hooks/ && chmod +x .git/hooks/*",
        "post-update-cmd": "cp hooks/* .git/hooks/ && chmod +x .git/hooks/*",
        "check-style": "vendor/bin/pint ./src ./tests --test",
        "pint": "vendor/bin/pint ./src ./tests",
        "fix-style": "vendor/bin/pint ./src ./tests",
        "test": "vendor/bin/pest",
        "phpstan": "vendor/bin/phpstan analyse"
    },
    "scripts-descriptions": {
        "test": "Run all tests.",
        "check-style": "Run style checks (only dry run - no fixing!).",
        "fix-style": "Run style checks and fix violations.",
        "phpstan": "Run static analysis with PHPStan."
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
